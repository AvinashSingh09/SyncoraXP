
# Node Environment
NODE_ENV=production
PORT=3000

# Domain configuration (Used by Caddy and CORS)
# Replace with your actual domain names (e.g. syncora.com and livekit.syncora.com)
DOMAIN_NAME=syncora.example.com
LIVEKIT_DOMAIN_NAME=livekit.syncora.example.com

# PostgreSQL Database Configuration (Neon or Supabase connection string)
# e.g., postgres://user:password@ep-cool-breeze-123456.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_MODE=postgres
DATABASE_URL=postgresql://postgres.xporgkowfmswcyjrxplw:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Web application base URL and CORS origins (pointing to your public domain)
APP_BASE_URL=https://syncora.example.com
CORS_ORIGIN=https://syncora.example.com

# LiveKit Configuration for the API Backend (returned to browser clients)
# This MUST be the public URL pointing to Caddy's secure endpoint
LIVEKIT_URL=wss://livekit.syncora.example.com
LIVEKIT_NODE_IP=103.189.88.94
LIVEKIT_API_KEY=syncoraxp-production-api-key
LIVEKIT_API_SECRET=syncoraxp-production-api-secret

# ZeptoMail Email Configuration
# Mode can be 'console' (for local CLI testing) or 'zeptomail' for live production
EMAIL_MODE=zeptomail
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTOMAIL_TOKEN=your_zeptomail_agent_send_mail_token
ZEPTOMAIL_FROM_ADDRESS=no-reply@your-verified-domain.com
ZEPTOMAIL_FROM_NAME=SyncoraXP
# Demo email for validation (if applicable)
ZEPTOMAIL_DEMO_RECEIVER=pictureofevent360@gmail.com

# Voice Translation Settings
# Can be 'fake' (simulated), 'openai', or 'gemini'
TRANSLATION_PROVIDER=gemini

# OpenAI Settings (required if TRANSLATION_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate

# Gemini Settings (required if TRANSLATION_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LIVE_TRANSLATION_MODEL=gemini-3.5-live-translate-preview
GEMINI_ECHO_TARGET_LANGUAGE=true
