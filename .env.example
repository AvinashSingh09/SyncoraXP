# API
PORT=3000
SESSION_DAYS=7
DATABASE_MODE=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/voice_meetings
APP_BASE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# LiveKit Cloud or self-hosted credentials. The API secret must remain server-side.
# For the LAN Docker stack, use the PC's LAN IP and generate strong local credentials.
LIVEKIT_URL=wss://192.168.0.195:7880
# Optional server-side signaling path. The local Docker stack exposes this only
# on loopback so native workers do not need to trust the development browser CA.
LIVEKIT_WORKER_URL=ws://127.0.0.1:7883
LIVEKIT_NODE_IP=192.168.0.195
LIVEKIT_API_KEY=replace_with_a_local_api_key
LIVEKIT_API_SECRET=replace_with_a_random_secret_at_least_32_characters_long

# Realtime interpretation worker. Keep the fake provider for local media-path testing;
# switch to openai or gemini only after setting the corresponding server-side API key.
TRANSLATION_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate
GEMINI_API_KEY=
GEMINI_LIVE_TRANSLATION_MODEL=gemini-3.5-live-translate-preview
GEMINI_ECHO_TARGET_LANGUAGE=true
TRANSLATION_JOB_POLL_MS=1000
TRANSLATION_WORKER_HEARTBEAT_MS=5000
TRANSLATION_WORKER_LEASE_MS=20000
TRANSLATION_LANGUAGE_IDLE_GRACE_MS=30000
TRANSLATION_MAX_QUEUE_MS=4000
TRANSLATION_FAKE_DELAY_MS=300

# Use "console" locally. Change to "zeptomail" after configuring a verified sender.
EMAIL_MODE=console
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM_ADDRESS=no-reply@syncoraxp.com
ZEPTOMAIL_FROM_NAME=VoiceMeet

# Virtual Events Fastify routes
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
GEMINI_API_KEY=
